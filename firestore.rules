rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Everything is readable publicly to secure smooth listing feeds, categories, settings, and messaging
    match /{document=**} {
      allow read: if true;
    }

    // Products
    match /products/{productId} {
      allow write: if request.auth != null;
    }

    // Categories
    match /categories/{categoryId} {
      allow write: if request.auth != null;
    }

    // Settings
    match /settings/{settingsId} {
      allow write: if request.auth != null;
    }

    // Admins
    match /admins/{adminId} {
      allow write: if request.auth != null;
    }

    // Vendors
    match /vendors/{vendorId} {
      allow write: if request.auth != null;
    }

    // Chats & Messages
    match /chats/{chatId} {
      allow write: if request.auth != null;
    }
    match /messages/{messageId} {
      allow write: if request.auth != null;
    }

    // Click Analytics
    match /clicks/{clickId} {
      allow write: if true; // Any visitor can trigger a card click count
    }
  }
}
