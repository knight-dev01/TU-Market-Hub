rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Public access
      allow write: if isSignedIn(); // Allow writing/editing for logged-in users
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true; // Public access
      allow write: if isSignedIn();
    }

    // Store Settings
    match /settings/{settingsId} {
      allow read: if true; // Public access
      allow write: if isSignedIn();
    }

    // Admins List
    match /admins/{adminId} {
      allow read: if true; // Publicly readable for verify checkers
      allow write: if isSignedIn();
    }

    // Vendors Details
    match /vendors/{vendorId} {
      allow read: if true; // Anyone can look up vendor details
      allow write: if isSignedIn() && request.auth.uid == vendorId; // Only owner can manage
    }

    // Click Analytics
    match /clicks/{clickId} {
      allow read: if true;
      allow write: if true; // Allows shopper-facing analytics click-through telemetry
    }

    // Communications / Chats
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    // Chat Messages
    match /messages/{messageId} {
      allow read, write: if isSignedIn();
    }
  }
}
